# Django
SECRET_KEY=change-me-in-production
DEBUG=0
ALLOWED_HOSTS=hamrohpos.uz,ona.hamrohpos.uz,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://hamrohpos.uz,https://ona.hamrohpos.uz
SECURE_PROXY_SSL_HEADER=1

# Database
DB_NAME=pos_cloud_db
DB_USER=cloud_user
DB_PASSWORD=change-me
DB_HOST=db
DB_PORT=5432

# Redis / Celery / Cache
REDIS_URL=redis://redis:6379/0

# Litsenziya JWT (RS256) - private key faqat shu serverda bo'ladi.
# `python manage.py generate_signing_keys` bilan generatsiya qiling,
# private qismini ./keys/license_private.pem ga saqlang.
LICENSE_PRIVATE_KEY_FILE=/app/keys/license_private.pem
LICENSE_TOKEN_TTL_DAYS=7

# Cloudflare Tunnel (prod only, docker-compose.prod.yml) - Cloudflare Zero
# Trust dashboardida tunnel yaratib, shu yerdan "run --token" tokenini
# oling. Ingress qoidasini (public hostname -> http://web:8001) ham
# dashboardda sozlang - token faqat autentifikatsiya qiladi, routingni
# emas. Bu maxfiy qiymat - hech qachon commit qilinmasin.
CLOUDFLARE_TUNNEL_TOKEN=change-me
