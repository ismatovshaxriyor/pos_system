# Django
SECRET_KEY=change-me-in-production
DEBUG=0
ALLOWED_HOSTS=ona.example.uz,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://ona.example.uz
SECURE_PROXY_SSL_HEADER=1

# Database
DB_NAME=pos_cloud_db
DB_USER=cloud_user
DB_PASSWORD=change-me
DB_HOST=db
DB_PORT=5432

# Redis / Celery / Cache
REDIS_URL=redis://redis:6379/0

# Litsenziya JWT (RS256) - private key faqat shu serverda bo'ladi.
# `python manage.py generate_signing_keys` bilan generatsiya qiling,
# private qismini ./keys/license_private.pem ga saqlang.
LICENSE_PRIVATE_KEY_FILE=/app/keys/license_private.pem
LICENSE_TOKEN_TTL_DAYS=7
