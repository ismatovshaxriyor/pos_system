# Environment files (contain secrets - never commit)
.env
.env.*
!.env.example

# Litsenziya imzo kalitlari (RSA private/public PEM)
keys/
*.pem

# Python
__pycache__/
*.pyc
*.egg-info/
.venv/
venv/

# Django
*.sqlite3
staticfiles/
media/

# Migrations are generated via `makemigrations` on container start (see
# entrypoint.sh) rather than committed, so environments never need to
# reconcile migration files by hand.
**/migrations/*.py
!**/migrations/__init__.py

# Celery
celerybeat-schedule
celerybeat.pid

# Backups
backups/

# OS / editor
.DS_Store
.idea/
.vscode/
