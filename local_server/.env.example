# Django
SECRET_KEY=change-me-in-production
DEBUG=0
ALLOWED_HOSTS=localhost,127.0.0.1
# Cloudflare Tunnel orqali masofaviy admin kirish uchun (docs/4):
CSRF_TRUSTED_ORIGINS=https://filial1.tizimingiz.uz
SECURE_PROXY_SSL_HEADER=1

# Database
DB_NAME=pos_local_db
DB_USER=pos_user
DB_PASSWORD=change-me
DB_HOST=db
DB_PORT=5432

# Redis / Celery / Cache
REDIS_URL=redis://redis:6379/0

# Ona (cloud) server bilan aloqa - bu .env faqat prod compose (docker-
# compose.prod.yml) tomonidan o'qiladi, shuning uchun shu yerda haqiqiy
# Ona domeni turishi kerak (dev'da esa docker-compose.yml o'zining
# host.docker.internal qiymatini alohida belgilaydi, bu faylga bog'liq
# emas).
ONA_SERVER_URL=https://ona.ismatov.uz

# Litsenziya JWT (RS256) - faqat public key, Bola token yasay olmaydi.
# Ona serverdagi `generate_signing_keys` chiqargan public qismini
# ./keys/license_public.pem ga saqlang.
LICENSE_PUBLIC_KEY_FILE=/app/keys/license_public.pem

# Kill-switch middleware'ni yoqish/o'chirish. Prod'da 1, lokal dev'da 0
# (Ona serverga ulanmasdan CRUD API bilan ishlash uchun).
LICENSE_ENFORCEMENT=0
LICENSE_CLOCK_SKEW_SECONDS=300
LICENSE_EXP_GRACE_SECONDS=0

# Faqat dev/test uchun: /sys/class/dmi/id/product_uuid o'qib bo'lmaydigan
# muhitlarda (masalan, macOS) qurilma barmoq izini qo'lda belgilaydi.
HARDWARE_ID_OVERRIDE=

# APP_VERSION bu yerda BERILMAYDI - versiya image ichidagi `local_server/VERSION`
# faylidan olinadi (config/settings.py). Shu tarzda Watchtower yangi image
# tortganda hisobot qilinadigan versiya avtomatik yangilanadi; bu yerda pin
# qilinsa, yangi image tortilsa ham eski versiya ko'rinib, update tekshiruvini
# buzardi. (Fayl topilmasa zaxira sifatida APP_VERSION env o'qiladi.)

# Watchtower HTTP API (Phase 5, faqat prod compose'da ishlatiladi)
WATCHTOWER_URL=http://watchtower:8080
WATCHTOWER_TOKEN=change-me

# Yangilanish tarqatish (Phase 5) - docker-compose.prod.yml'dagi web/
# celery_worker/celery_beat shu manzildan image tortadi. ORG'ni haqiqiy
# GitHub user/org nomiga almashtiring (yoki shu yerda to'liq POS_IMAGE
# bering); RELEASE_CHANNEL - image tegi, bir xil kanaldagi barcha
# restoranlar birga yangilanadi (masalan stable/beta).
POS_IMAGE=ghcr.io/ORG/pos-local
RELEASE_CHANNEL=stable

# Cloudflare Tunnel (docs/4) - Zero Trust panelida shu restoran uchun
# yaratilgan tunnel connector tokeni (Public Hostname'ning o'zi emas -
# u yuqoridagi CSRF_TRUSTED_ORIGINS'ga qo'yiladi).
CLOUDFLARE_TUNNEL_TOKEN=change-me
