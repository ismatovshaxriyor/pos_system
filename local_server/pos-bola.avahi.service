<?xml version="1.0" standalone='no'?>
<!DOCTYPE service-group SYSTEM "avahi-service.dtd">
<!--
  Bola (local_server) ni restoran WiFi tarmog'ida mDNS orqali e'lon
  qiladi - statik IP band qilish yoki DHCP reservation shart emas.
  O'rnatish: docs/4_amaliy_ish_oqimi_va_deployment.md ga qarang.
-->
<service-group>
  <name replace-wildcards="yes">POS Bola Server (%h)</name>
  <service>
    <type>_pos-bola._tcp</type>
    <port>8000</port>
    <txt-record>path=/api/</txt-record>
    <txt-record>service=pos-bola</txt-record>
    <txt-record>version=1.0.0</txt-record>
  </service>
</service-group>

