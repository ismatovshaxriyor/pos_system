# Django
SECRET_KEY=Zkf_T93ekwpj6nfQAGBiYDjqw1nkoYlfioCX_Szpkv80H7W4DSl3_dVDTySggd-Fr0g
DEBUG=0
ALLOWED_HOSTS=localhost,127.0.0.1
# Cloudflare Tunnel orqali masofaviy admin kirish uchun (docs/4) - shu
# restoranning O'ZI uchun Cloudflare'da belgilangan Public Hostname shu yerga
# to'liq sxema bilan qo'yiladi (masalan https://filial1.tizimingiz.uz).
# Hali haqiqiy domen tanlanmagani uchun bo'sh qoldirilgan - Ona serverning
# domeni (ona.ismatov.uz) bu yerga XATO qo'yilgan edi, olib tashlandi.
CSRF_TRUSTED_ORIGINS=
SECURE_PROXY_SSL_HEADER=1

# Database
DB_NAME=pos_local_db
DB_USER=pos_user
DB_PASSWORD=pos_password
DB_HOST=db
DB_PORT=5432

# Redis / Celery / Cache
REDIS_URL=redis://redis:6379/0

# Ona (cloud) server bilan aloqa - bu .env faqat prod compose (docker-
# compose.prod.yml) tomonidan o'qiladi, shuning uchun shu yerda haqiqiy
# Ona domeni turishi kerak (dev'da esa docker-compose.yml o'zining
# host.docker.internal qiymatini alohida belgilaydi, bu faylga bog'liq
# emas).
ONA_SERVER_URL=https://ona.ismatov.uz

# Litsenziya JWT (RS256) - faqat public key, Bola token yasay olmaydi.
# Ona serverdagi `generate_signing_keys` chiqargan public qismini
# ./keys/license_public.pem ga saqlang.
LICENSE_PUBLIC_KEY_FILE=/app/keys/license_public.pem

# Kill-switch middleware'ni yoqish/o'chirish. Prod'da 1, lokal dev'da 0
# (Ona serverga ulanmasdan CRUD API bilan ishlash uchun).
LICENSE_ENFORCEMENT=0
LICENSE_CLOCK_SKEW_SECONDS=300
LICENSE_EXP_GRACE_SECONDS=0

# Faqat dev/test uchun: /sys/class/dmi/id/product_uuid o'qib bo'lmaydigan
# muhitlarda (masalan, macOS) qurilma barmoq izini qo'lda belgilaydi.
HARDWARE_ID_OVERRIDE=dev-local-machine

CLOUDFLARE_TUNNEL_TOKEN=eyJhIjoiZWFkNWYzNGRkZDFjY2Q5MmJkZjg4NDk0NWQ2NDM2YTUiLCJ0IjoiMThhZWMyMjYtZjI2Yy00NTk0LWEyNTYtYTNlNDI1Njg4Y2U5IiwicyI6IllqUTFOamRtWW1FdFltSTNZUzAwT1dNeUxUZ3lZbUV0T0Rrd1pEWTROVFF4TWpKbSJ9

# APP_VERSION endi image ichidagi local_server/VERSION faylidan (settings.py).

# Watchtower HTTP API (Phase 5, faqat prod compose'da ishlatiladi)
WATCHTOWER_URL=http://watchtower:8080
WATCHTOWER_TOKEN=025GZAjNByUM-sArPP-k9uN7qgzmlRiZnWsoVXADDjw

# Yangilanish tarqatish (Phase 5)
POS_IMAGE=ghcr.io/ismatovshaxriyor/pos-local
RELEASE_CHANNEL=stable
